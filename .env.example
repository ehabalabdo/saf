# MED LOOP - Environment Variables
# Copy this file to .env and fill in your actual values

# API Configuration (Backend on Render)
VITE_API_URL=https://medloop-api.onrender.com

# NOTE: The frontend no longer connects directly to the database.
# All data goes through the backend API (medloop-api).
# DATABASE_URL is only needed for local scripts (e.g. scripts/clearPatients.ts).

# Security Note:
# - Never commit .env file to version control
# - Keep your database credentials secret
# - Use environment variables in production deployments
